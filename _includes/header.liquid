<header>
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" aria-label="Primary navigation">
    <div class="container">
      <a class="navbar-brand title" href="{{ '/' | relative_url }}">Home</a>
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for nav_page in sorted_pages %}
            {% if nav_page.nav %}
              <li class="nav-item {% if page.url == nav_page.url %}active{% endif %}">
                <a class="nav-link" href="{{ nav_page.url | relative_url }}">
                  {{- nav_page.title -}}
                  {% if page.url == nav_page.url %}<span class="sr-only"> (current)</span>{% endif %}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </nav>
</header>
